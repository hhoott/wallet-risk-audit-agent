# Wallet Risk Audit Agent — environment variables
#
# Copy this file to `.env` and fill in the values, then run:
#   npm run preflight     # validate your .env
#   npm start             # start the Provider (loads .env automatically)
#
# All values are injected via the environment and are NEVER hard-coded in source.
# `.env` is gitignored — do not commit real keys.

# ─────────────────────────────────────────────────────────────────────────────
# CAP / CROO (settlement side, USDC on Base) — MANUAL(H1-1, H1-2)
# ─────────────────────────────────────────────────────────────────────────────

# Required. Produced when you register the Agent at https://agent.croo.network
# (shown ONLY once — store it securely). SDK auth via the X-SDK-Key header.
CROO_SDK_KEY=croo_sk_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional. Defaults shown — only set these to override.
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws

# Required for a live Provider. Produced after you configure the three Services
# in the Agent Store Dashboard (one Service per tier). Each maps a Service to a tier.
SERVICE_ID_QUICK=svc_xxxxxxxx_quick
SERVICE_ID_FULL=svc_xxxxxxxx_full
SERVICE_ID_MULTI=svc_xxxxxxxx_multi

# Optional. Settlement-side RPC (Base). Defaults to Base mainnet inside the SDK.
# RPC_URL=https://mainnet.base.org

# ─────────────────────────────────────────────────────────────────────────────
# Audited chain data sources (Ethereum Mainnet, READ-ONLY) — MANUAL(H7-12)
# ─────────────────────────────────────────────────────────────────────────────

# Required. Etherscan v2 API key — https://etherscan.io/myapikey
# Used for transaction history, contract source/creation, token transfers.
ETHERSCAN_API_KEY=YourEtherscanApiKey

# Recommended. HTTP RPC URL for viem read-only calls (allowances, balances, code).
# Any provider works (Alchemy, Infura, public RPC). Falls back to a public keyless RPC if unset.
ALCHEMY_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YourAlchemyKey

# Optional. CoinGecko key for USD valuations (raises rate limits). Demo key by default.
# COINGECKO_API_KEY=CG-xxxxxxxxxxxxxxxxxxxx
# Set to "true" if COINGECKO_API_KEY is a Pro key (uses the pro base URL + header).
# COINGECKO_PRO=false

# ─────────────────────────────────────────────────────────────────────────────
# Example Requester (optional — only for the A2A demo, `npm run requester`)
# ─────────────────────────────────────────────────────────────────────────────

# The Service_ID of the audit agent you want to hire (one of the three above, or another agent's).
# CROO_TARGET_SERVICE_ID=svc_xxxxxxxx_full
# The created order id (from the order_created event after the Provider accepts the negotiation).
# CROO_TARGET_ORDER_ID=order_xxxxxxxx
# The wallet to audit (can also be passed as the first CLI arg).
# CROO_AUDIT_WALLET=0xd8da6bf26964af9d7eed9e03e53415d37aa96045
