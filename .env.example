# Web3 Address Intel & Risk Agent — environment variables
#
# Copy this file to `.env` and fill in the values, then run:
#   npm run preflight     # validate your .env
#   npm start             # start Provider + Web/API together (loads .env automatically)
#
# All values are injected via the environment and are NEVER hard-coded in source.
# `.env` is gitignored — do not commit real keys.

# ─────────────────────────────────────────────────────────────────────────────
# CAP / CROO (settlement side, USDC on Base) — MANUAL(H1-1, H1-2)
# ─────────────────────────────────────────────────────────────────────────────

# Required. Produced when you register the Agent at https://agent.croo.network
# (shown ONLY once — store it securely). SDK auth via the X-SDK-Key header.
CROO_SDK_KEY=croo_sk_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional. Defaults shown — only set these to override.
CROO_API_URL=https://api.croo.network
CROO_WS_URL=wss://api.croo.network/ws

# Required for a live Provider. Produced after you configure the single Service
# in the Agent Store Dashboard.
SERVICE_ID=svc_xxxxxxxx_address_intel

# Optional. Settlement-side RPC (Base). Defaults to Base mainnet inside the SDK.
# RPC_URL=https://mainnet.base.org

# ─────────────────────────────────────────────────────────────────────────────
# Audited chain data sources (multi-chain, READ-ONLY) — MANUAL(H7-12)
# ─────────────────────────────────────────────────────────────────────────────

# Required. Etherscan V2 API key — https://etherscan.io/myapikey
# Etherscan V2 is single-key, multi-chain: the same key queries 60+ EVM chains by switching the
# `chainid` parameter (the audit selects it per request). Used for transaction history, contract
# source/creation, and token transfers.
# NOTE: the FREE Etherscan plan only covers Ethereum Mainnet for the list endpoints (txlist etc.).
# Auditing Base / Arbitrum / Optimism / Polygon transaction HISTORY requires a paid Etherscan plan.
# RPC-based checks (address type, balances, approvals, contract metadata) work on all chains via the
# per-chain RPCs below even on the free plan.
ETHERSCAN_API_KEY=YourEtherscanApiKey

# Recommended. Per-chain HTTP RPC URLs for viem read-only calls (allowances, balances, code, type).
# Any provider works (Alchemy, Infura, public RPC). Each falls back to a public keyless RPC if unset.
# ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YourAlchemyKey
# BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YourAlchemyKey
# ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YourAlchemyKey
# OPTIMISM_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YourAlchemyKey
# POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YourAlchemyKey
# Legacy alias for the Ethereum RPC (still honored for backward compatibility):
ALCHEMY_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YourAlchemyKey

# Optional. CoinGecko key for USD valuations (raises rate limits). Demo key by default.
# The audit selects the right CoinGecko platform / native coin per chain automatically.
# COINGECKO_API_KEY=CG-xxxxxxxxxxxxxxxxxxxx
# Set to "true" if COINGECKO_API_KEY is a Pro key (uses the pro base URL + header).
# COINGECKO_PRO=false

# ─────────────────────────────────────────────────────────────────────────────
# Example Requester (optional — only for the A2A demo, `npm run requester`)
# ─────────────────────────────────────────────────────────────────────────────

# The Service_ID of the audit agent you want to hire.
# CROO_REQUESTER_SDK_KEY=croo_sk_requester_agent_key
# CROO_TARGET_SERVICE_ID=svc_xxxxxxxx_address_intel
# The created order id (from the order_created event after the Provider accepts the negotiation).
# CROO_TARGET_ORDER_ID=order_xxxxxxxx
# The address target to inspect (can also be passed as the first CLI arg).
# CROO_AUDIT_WALLET=0xd8da6bf26964af9d7eed9e03e53415d37aa96045

# ─────────────────────────────────────────────────────────────────────────────
# Web/API Portal (optional — bundled with `npm start`, standalone via `npm run portal`)
# ─────────────────────────────────────────────────────────────────────────────
#
# In the default unified process, the portal reuses the Provider's in-process audit engine. It does
# not open a second CAP WebSocket. Payment is controlled by PORTAL_PAYMENT_MODE:
#   free -> demo/dev mode; payment failures do not block returning a local read-only report.
#   paid -> strict mode; a CAP checkout or verified MetaMask/Base USDC payment must succeed.
#
# SECURITY: the portal has no built-in auth or rate limiting. Keep it on localhost or put it behind
# your own auth before exposing it.

# The portal reuses SERVICE_ID above for CAP checkout / A2A payment flows.

# Optional. HTTP port the portal listens on (default 8787).
# PORTAL_PORT=8787
# Optional. Per-order timeout in ms for the full negotiate→pay→deliver round trip (default 120000).
# PORTAL_ORDER_TIMEOUT_MS=120000

# Payment mode: "free" (default demo fallback) or "paid" (strict settlement).
#   free -> DEV/DEMO ONLY. Payment failure is ignored and the local read-only report is returned.
#   paid -> a CAP checkout or verified MetaMask/Base USDC transfer must succeed, or the order fails.
# PORTAL_PAYMENT_MODE=free

# Demo CAP checkout path. OFF by default. When true, the browser/API may accept a user-supplied
# CROO key for a single checkout. The key is not stored or logged.
# PORTAL_ALLOW_CROO_KEY=false

# MetaMask direct-transfer path. The user sends Base USDC to PORTAL_PAYEE_ADDRESS and submits the
# tx hash; the server verifies the receipt and USDC Transfer log.
# PORTAL_PAYEE_ADDRESS=0xYourBaseUsdcPayeeAddress
# PORTAL_BASE_RPC_URL=https://mainnet.base.org

# ─────────────────────────────────────────────────────────────────────────────
# Optional LLM insight layer
# ─────────────────────────────────────────────────────────────────────────────
#
# When LLM_API_KEY is absent, the deterministic audit still works. When present, reports
# can include additive AI explanations and remediation guidance through a LangChain
# OpenAI-compatible chat model.
# LLM_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxx
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# LLM_TEMPERATURE=0.2
# LLM_MAX_TOKENS=1200
# Log each LLM call (skill, latency, prompt/response size, token usage) to the console. The API key,
# prompts and responses are never logged — only sizes. Default true; set to false to silence.
# LLM_LOG=true
